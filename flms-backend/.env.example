# Copy to .env — never commit .env to GitHub!

# Database
DATABASE_URL=sqlite:///./flms.db

# JWT Secret — change this to a long random string in production!
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
APP_NAME=FLMS
DEBUG=True
